# Trophy Store Backend - Environment Configuration
# Copy this to .env and update values for your environment

# ========================================
# DATABASE
# ========================================
DATABASE_URL=postgresql://postgres:root@localhost:5432/trophy_store
REDIS_URL=redis://localhost:6379/0

# ========================================
# JWT & Security
# ========================================
SECRET_KEY=your-super-secret-key-change-in-production-use-uvicorn-or-generate-with-openssl
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=30

# ========================================
# CORS
# ========================================
BACKEND_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:8080

# ========================================
# Payments - Stripe
# ========================================
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PUBLISHABLE_KEY=pk_test_...

# ========================================
# Payments - PayPal
# ========================================
PAYPAL_CLIENT_ID=...
PAYPAL_CLIENT_SECRET=...
PAYPAL_WEBHOOK_ID=...

# ========================================
# Payments - Adyen
# ========================================
ADYEN_API_KEY=...
ADYEN_CLIENT_KEY=...
ADYEN_HMAC_KEY=...

# ========================================
# File Storage
# ========================================
MAX_FILE_SIZE_MB=10
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/webp,application/pdf

# ========================================
# Email (SMTP)
# ========================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
FROM_EMAIL=noreply@yourstore.com

# ========================================
# External Services
# ========================================
FRONTEND_URL=http://localhost:3000
